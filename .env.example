# Client API base (same-origin integrated server proxy)
VITE_OPENSPLINKLER_BASE_URL=/api/os

# Controller target URL (server-side only)
OS_BASE_URL=http://192.168.1.50
OS_PORT=8080

# Controller auth on server-side only (set one)
OS_PASSWORD=opendoor
# OS_PW_HASH=md5_hash_here

# HydroDash app login/session
HYDRODASH_LOGIN_PASSWORD=changeme
HYDRODASH_SESSION_SECRET=replace_with_long_random_secret
