# Used by Docker Compose for `${VAR}` substitution (same directory as docker-compose.yml).
# Also used by `npm run dev` / `npm run build` for Vite and the dev server.
# Full reference: docs/environment.md
#
# Compose builds DATABASE_URL and DATABASE_SCHEMA_URL from MARIADB_* in docker-compose.yml
# (Vaultwarden-style). You do not set DATABASE_* in .env for `docker compose up`.

# --- MariaDB (same values seed the DB container and compose the app connection URLs) ---
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=

# --- OpenSprinkler (server-side). Set OS_PASSWORD and/or OS_PW_HASH (can leave one empty). ---
OS_BASE_URL=
OS_PORT=
OS_PASSWORD=
OS_PW_HASH=

# OS_SITES=[{"id":"a","baseUrl":"http://192.168.1.50","password":"secret"}]

# --- HydroDash UI (web only; notify worker does not need login password) ---
HYDRODASH_LOGIN_PASSWORD=
HYDRODASH_SESSION_SECRET=

# --- Vite preview (docker `npm run start`): public hostname(s) behind reverse proxy (comma-separated).
# Empty = allow any Host (default). Example: PREVIEW_ALLOWED_HOSTS=hydrodash.example.com
PREVIEW_ALLOWED_HOSTS=

# --- Local dev only: app on host, DB in Docker or elsewhere (Compose ignores if you only run compose) ---
# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/hydrodash
# DATABASE_SCHEMA_URL=mysql://root:...@127.0.0.1:3306/hydrodash

# --- Optional: Vite (default /api/os in code if unset at build time) ---
# VITE_OPENSPLINKER_BASE_URL=/api/os

# --- Optional: ntfy + worker (add KEY: ${KEY} to compose when used; see docs/environment.md) ---
# NTFY_SERVER_URL=
# NTFY_ACCESS_TOKEN=
# NOTIFICATIONS_POLL_INTERVAL_SEC=
# NOTIFICATIONS_RETENTION_DAYS=
# NOTIFICATIONS_HEALTH_PORT=
# NOTIFICATIONS_HEALTH_DISABLE=
# NOTIFICATIONS_ENABLED=
